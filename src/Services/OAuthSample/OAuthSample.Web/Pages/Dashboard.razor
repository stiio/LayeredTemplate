@page "/dashboard"
@attribute [Authorize]
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

<div class="mb-3">
    <button class="btn btn-warning" @onclick="RefreshToken">Refresh Token</button>
    <button class="btn btn-info" @onclick="FetchProfile">Fetch /connect/userinfo</button>
    <button class="btn btn-danger" @onclick="Logout">Logout</button>
</div>

@if (!string.IsNullOrEmpty(profileResult))
{
    <div class="alert alert-info">
        <h5>UserInfo Response:</h5>
        <pre>@profileResult</pre>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<h3>User Claims</h3>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Type</th>
            <th>Value</th>
        </tr>
    </thead>
    <tbody>
        <AuthorizeView>
            <Authorized>
                @foreach (var claim in context.User.Claims)
                {
                    <tr>
                        <td><code>@claim.Type</code></td>
                        <td>@claim.Value</td>
                    </tr>
                }
            </Authorized>
        </AuthorizeView>
    </tbody>
</table>

<h3>Tokens</h3>
@if (accessToken is not null)
{
    <div class="mb-3">
        <h5>Access Token</h5>
        <textarea class="form-control" rows="6" readonly>@accessToken</textarea>
    </div>
}
@if (refreshToken is not null)
{
    <div class="mb-3">
        <h5>Refresh Token</h5>
        <textarea class="form-control" rows="3" readonly>@refreshToken</textarea>
    </div>
}

@code {
    private string? accessToken;
    private string? refreshToken;
    private string? profileResult;
    private string? errorMessage;

    [Inject]
    private IAccessTokenProvider TokenProvider { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    [Inject]
    private HttpClient Http { get; set; } = default!;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadTokens();
    }

    private async Task LoadTokens()
    {
        var tokenResult = await TokenProvider.RequestAccessToken();
        if (tokenResult.TryGetToken(out var token))
        {
            accessToken = token.Value;
        }
    }

    private async Task RefreshToken()
    {
        errorMessage = null;
        try
        {
            // Force a silent sign-in which triggers the OIDC refresh_token flow
            var result = await JS.InvokeAsync<JsonElement>(
                "AuthenticationService.getAccessToken");

            accessToken = result.GetString();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Refresh error: {ex.Message}";
        }
    }

    private async Task FetchProfile()
    {
        errorMessage = null;
        profileResult = null;

        try
        {
            var tokenResult = await TokenProvider.RequestAccessToken();
            if (!tokenResult.TryGetToken(out var token))
            {
                errorMessage = "No access token available.";
                return;
            }

            var request = new HttpRequestMessage(HttpMethod.Get, "https://localhost:8080/connect/userinfo");
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token.Value);

            var response = await Http.SendAsync(request);
            profileResult = await response.Content.ReadAsStringAsync();

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"UserInfo returned {(int)response.StatusCode}: {profileResult}";
                profileResult = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fetch error: {ex.Message}";
        }
    }

    private void Logout()
    {
        Navigation.NavigateToLogout("authentication/logout");
    }
}
