{
  "Serilog": {
    "Using": [ "Serilog.Exceptions", "Serilog", "Serilog.Sinks.Console", "Serilog.Exceptions.EntityFrameworkCore" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Information",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information"
        }
      }
    ],
    "Properties": {
      "Application": "LayeredTemplate.Auth"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AuthDbConnection": "Host=localhost;Port=5432;Database=authDbName;Username=postgres;Password=postgres"
  },
  "DataProtectionSettings": {
    "CertificateBase64": "",
    "CertificatePassword": "",
    "UnprotectCertificates": [
      {
        "Base64": "",
        "Password": ""
      }
    ]
  },
  "ReCaptchaSettings": {
    "SiteKey": "",
    "SecretKey": ""
  },
  "AppSettings": {
    "UseMockEmailSender": false,
    "UseMockSmsSender": false,
    "EnablePhoneConfirmation": true,
    "EnableDeletePersonalData": false
  },
  "CorsSettings": {
    "AllowedOrigins": []
  },
  "SmtpSettings": {
    "Form": "",
    "Host": "",
    "Port": 485,
    "User": "",
    "Password": ""
  }
}
