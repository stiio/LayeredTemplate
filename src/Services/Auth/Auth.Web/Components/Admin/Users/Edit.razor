@page "/admin/users/edit/{id}"

<PageTitle>Manage user</PageTitle>

<div class="admin-header">
    <h3>User</h3>
    <a href="admin/users" class="btn btn-default">Back</a>
</div>

<StatusMessage Message="@message" />

@if (notFound)
{
    <p>User not found.</p>
}
else if (view is not null)
{
    <div class="card" style="max-width: 640px;">
        <div class="form-group">
            <label class="form-label">Email</label>
            <div>@view.Email @(view.EmailConfirmed ? "✓" : "— unconfirmed")</div>
        </div>
        <div class="form-group">
            <label class="form-label">Phone</label>
            <div>@(view.PhoneNumber ?? "—") @(view.PhoneConfirmed ? "✓" : "")</div>
        </div>
        <div class="form-group">
            <label class="form-label">Has password</label>
            <div>@(view.HasPassword ? "Yes" : "No (external login only)")</div>
        </div>
        <div class="form-group">
            <label class="form-label">Roles</label>
            <div>@(view.Roles.Count == 0 ? "—" : string.Join(", ", view.Roles))</div>
        </div>
    </div>

    <hr style="margin: 32px 0;" />
    <h4>Email</h4>

    <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        @if (!view.EmailConfirmed)
        {
            <form method="post" @formname="confirm-email" @onsubmit="OnConfirmEmailAsync">
                <AntiforgeryToken />
                <button type="submit" class="btn-default">Mark email confirmed</button>
            </form>
            <form method="post" @formname="send-confirmation" @onsubmit="OnSendConfirmationAsync">
                <AntiforgeryToken />
                <button type="submit" class="btn-default">Send confirmation email</button>
            </form>
        }
    </div>

    <hr style="margin: 32px 0;" />
    <h4>Password</h4>

    <form method="post" @formname="send-reset" @onsubmit="OnSendPasswordResetAsync" style="margin-bottom: 16px;">
        <AntiforgeryToken />
        <button type="submit" class="btn-default">Send password reset email</button>
    </form>

    <EditForm Model="PwdInput" method="post" FormName="set-password" OnValidSubmit="OnSetPasswordAsync">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label class="form-label" for="PwdInput.NewPassword">New password</label>
            <InputText @bind-Value="PwdInput.NewPassword" name="PwdInput.NewPassword" type="password"
                       class="form-input" style="max-width: 360px;" />
            <ValidationMessage For="() => PwdInput.NewPassword" />
        </div>
        <button type="submit" class="btn-danger">Set password manually</button>
    </EditForm>
}
