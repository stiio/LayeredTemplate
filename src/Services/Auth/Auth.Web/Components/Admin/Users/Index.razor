@page "/admin/users"

<PageTitle>Users</PageTitle>

<div class="admin-header">
    <h3>Users</h3>
    <a href="admin/users/create" class="btn btn-primary">New user</a>
</div>

<EditForm Model="Input" method="post" FormName="user-search" OnValidSubmit="OnSearchAsync">
    <div class="admin-toolbar">
        <label class="form-label" style="margin: 0;" for="@Input.Email">Email contains</label>
        <InputText @bind-Value="Input.Email" name="Input.Email" class="form-input" style="flex: 1; max-width: 360px;"
                   placeholder="name@example.com" />
        <button type="submit" class="btn-primary">Search</button>
    </div>
</EditForm>

@if (results is null)
{
    <p style="color: #87867f;">Enter an email fragment to search.</p>
}
else if (results.Count == 0)
{
    <p>No users match.</p>
}
else
{
    <p style="color: #87867f;">@(results.Count == MaxResults ? $"Showing first {MaxResults} matches — narrow your search." : $"Found {results.Count}.")</p>
    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Email</th>
                <th>Phone</th>
                <th>2FA</th>
                <th class="col-actions">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in results)
            {
                <tr>
                    <td>
                        <span class="id-cell" title="@u.Id">
                            @u.Id[..8]
                            <button type="button" class="btn-copy" data-copy="@u.Id"
                                    title="Copy ID" aria-label="Copy ID">
                                <span class="icon icon-copy" aria-hidden="true"></span>
                            </button>
                        </span>
                    </td>
                    <td>
                        <span class="cell-with-status">
                            @u.Email
                            <span class="@(u.EmailConfirmed ? "status-verified" : "status-unverified")">
                                @(u.EmailConfirmed ? "\u2713" : "\u2717")
                            </span>
                        </span>
                    </td>
                    <td>
                        @if (string.IsNullOrEmpty(u.PhoneNumber))
                        {
                            <span style="color: #87867f;">—</span>
                        }
                        else
                        {
                            <span class="cell-with-status">
                                @u.PhoneNumber
                                <span class="@(u.PhoneNumberConfirmed ? "status-verified" : "status-unverified")">
                                    @(u.PhoneNumberConfirmed ? "\u2713" : "\u2717")
                                </span>
                            </span>
                        }
                    </td>
                    <td>
                        <span class="@(u.TwoFactorEnabled ? "status-verified" : "status-unverified")">
                            @(u.TwoFactorEnabled ? "\u2713" : "\u2717")
                        </span>
                    </td>
                    <td class="col-actions">
                        <a href="@($"admin/users/details/{u.Id}")"
                           class="btn btn-default btn-icon" title="Manage" aria-label="Manage">
                            <span class="icon icon-edit" aria-hidden="true"></span>
                        </a>
                        <a href="@($"admin/users/delete/{u.Id}")"
                           class="btn btn-danger btn-icon" title="Delete" aria-label="Delete">
                            <span class="icon icon-delete" aria-hidden="true"></span>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
