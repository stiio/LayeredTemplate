@* Shared form fields for Create/Edit. Host component owns the EditForm, Model and SubmitHandler. *@

<div class="form-group">
    <label class="form-label" for="@Model.ClientId">Client ID</label>
    <InputText @bind-Value="Model.ClientId" name="Input.ClientId" class="form-input" readonly="@ClientIdReadonly" />
    <ValidationMessage For="() => Model.ClientId" />
</div>

<div class="form-group">
    <label class="form-label" for="@Model.DisplayName">Display name</label>
    <InputText @bind-Value="Model.DisplayName" name="Input.DisplayName" class="form-input" />
    <ValidationMessage For="() => Model.DisplayName" />
</div>

<div class="form-group">
    <label class="form-label">Client type</label>
    @if (ClientTypeReadonly)
    {
        <div class="form-input-static">
            @(Model.ClientType == ClientTypeOption.Public ? "Public" : "Confidential")
        </div>
        <input type="hidden" name="Input.ClientType" value="@Model.ClientType" />
        <small style="color: #87867f;">Type cannot be changed after creation — recreate the application to switch.</small>
    }
    else
    {
        <InputRadioGroup @bind-Value="Model.ClientType" name="Input.ClientType">
            <label style="margin-right: 16px;">
                <InputRadio Value="ClientTypeOption.Confidential" /> Confidential
            </label>
            <label>
                <InputRadio Value="ClientTypeOption.Public" /> Public
            </label>
        </InputRadioGroup>
        <small style="color: #87867f; display: block; margin-top: 4px;">Public clients have no client secret (SPAs, mobile). Confidential clients authenticate with a secret.</small>
    }
</div>

<div class="form-group">
    <label class="form-label" for="@Model.RedirectUris">Redirect URIs (one per line)</label>
    <InputTextArea @bind-Value="Model.RedirectUris" name="Input.RedirectUris" class="form-input" rows="4" />
</div>

<div class="form-group">
    <label class="form-label" for="@Model.PostLogoutRedirectUris">Post-logout redirect URIs (one per line)</label>
    <InputTextArea @bind-Value="Model.PostLogoutRedirectUris" name="Input.PostLogoutRedirectUris" class="form-input" rows="3" />
</div>

<div class="form-group">
    <label class="form-label">Grant types</label>
    <div><label><InputCheckbox @bind-Value="Model.AllowAuthorizationCode" name="Input.AllowAuthorizationCode" /> Authorization Code</label></div>
    <div><label><InputCheckbox @bind-Value="Model.AllowRefreshToken" name="Input.AllowRefreshToken" /> Refresh Token</label></div>
    <div><label><InputCheckbox @bind-Value="Model.AllowClientCredentials" name="Input.AllowClientCredentials" /> Client Credentials</label></div>
    <div><label><InputCheckbox @bind-Value="Model.AllowPassword" name="Input.AllowPassword" /> Password</label></div>
</div>

<div class="form-group">
    <label class="form-label">Scopes</label>
    @if (AvailableScopes.Count == 0)
    {
        <small style="color: #87867f;">No scopes registered. Seed scopes via <code>IOpenIddictScopeManager</code> before assigning them.</small>
    }
    else
    {
        @foreach (var scope in AvailableScopes)
        {
            <div>
                <label>
                    <input type="checkbox" name="Input.Scopes" value="@scope"
                           checked="@Model.Scopes.Contains(scope)" />
                    @scope
                </label>
            </div>
        }
    }
</div>

<div class="form-group">
    <label><InputCheckbox @bind-Value="Model.RequirePkce" name="Input.RequirePkce" /> Require PKCE</label>
</div>

@code {
    [Parameter, EditorRequired]
    public ApplicationFormModel Model { get; set; } = default!;

    [Parameter]
    public bool ClientIdReadonly { get; set; }

    [Parameter]
    public bool ClientTypeReadonly { get; set; }

    [Parameter]
    public IReadOnlyList<string> AvailableScopes { get; set; } = [];
}
