@page "/Account/ForgotPassword"

<PageTitle>Forgot your password?</PageTitle>

<h1>Forgot your password?</h1>
<h2>Enter your email.</h2>
<hr/>

<div style="max-width:400px;">
    <form method="post" @formname="forgot-password" @onsubmit="OnValidSubmitAsync">
        <AntiforgeryToken />

        <div style="margin-bottom:16px;">
            <label for="Input.Email" style="display:block; margin-bottom:4px; font-weight:500;">Email</label>
            <input name="Input.Email" id="Input.Email" value="@Input.Email" style="width:100%; padding:8px 12px; border:1px solid #d9d9d9; border-radius:6px; font-size:14px;" autocomplete="username" aria-required="true" placeholder="name@example.com" />
        </div>
        <button type="submit" style="width:100%; padding:8px 16px; background:#1677ff; color:white; border:none; border-radius:6px; cursor:pointer; font-size:16px;">Reset password</button>
    </form>
</div>
