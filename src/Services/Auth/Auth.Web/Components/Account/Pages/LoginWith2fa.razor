@page "/Account/LoginWith2fa"

<PageTitle>Two-factor authentication</PageTitle>

<div class="card">
    <h3 style="text-align: center;">Two-factor authentication</h3>

    <hr />

    <StatusMessage Message="@message"/>

    <p>Your login is protected with an authenticator app. Enter your authenticator code below.</p>

    <EditForm Model="Input" method="post" FormName="login-with-2fa" OnValidSubmit="OnValidSubmitAsync">
        <DataAnnotationsValidator />

        <input type="hidden" name="ReturnUrl" value="@ReturnUrl"/>
        <input type="hidden" name="RememberMe" value="@RememberMe"/>

        <div class="form-group">
            <label for="Input.TwoFactorCode" class="form-label">Authenticator code</label>
            <InputText @bind-Value="Input.TwoFactorCode" name="Input.TwoFactorCode" id="Input.TwoFactorCode"
                   class="form-input" />
        </div>

        <div class="form-group">
            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                <input type="checkbox" name="Input.RememberMachine" value="true" checked="@Input.RememberMachine" />
                Remember this machine
            </label>
        </div>

        <button type="submit" class="btn-primary btn-block">Log in</button>
    </EditForm>

    <hr />

    <p>
        Don't have access to your authenticator device? You can
        <a href="Account/LoginWithRecoveryCode?ReturnUrl=@ReturnUrl">log in with a recovery code</a>.
    </p>
</div>
