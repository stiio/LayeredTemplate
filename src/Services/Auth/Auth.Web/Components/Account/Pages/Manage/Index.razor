@page "/account/manage"

<PageTitle>Profile</PageTitle>

<h3>Profile</h3>
<StatusMessage/>

<div class="card">

    <div class="form-group">
        <label class="form-label">Name</label>
        <div class="field-row">
            <input type="text" value="@(fullName ?? "Not set")" disabled class="form-input" />
            <span class="status-icon-spacer"></span>
        </div>
        <div class="field-actions">
            <a href="account/manage/edit_profile" class="btn btn-default field-action">Edit</a>
        </div>
    </div>

    <div class="form-group">
        <label class="form-label">Email</label>
        <div class="field-row">
            <input type="text" value="@(email ?? "Not set")" disabled class="form-input" />
            <span class="@(isEmailConfirmed ? "status-verified" : "status-unverified")">
                @(isEmailConfirmed ? "\u2713" : "\u2717")
            </span>
        </div>
        <div class="field-actions">
            <a href="account/manage/edit_email" class="btn btn-default field-action">Edit</a>
            @if (!isEmailConfirmed)
            {
                <form method="post" @formname="send-verification" @onsubmit="OnSendEmailVerificationAsync" style="display:inline;">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-default field-action">Confirm Email</button>
                </form>
            }
        </div>
    </div>

    <div class="form-group">
        <label class="form-label">Phone</label>
        <div class="field-row">
            <input type="text" value="@(phoneNumber ?? "Not set")" disabled class="form-input" data-phone-display />
            @if (IsPhoneConfirmationEnabled)
            {
                <span class="@(isPhoneConfirmed ? "status-verified" : "status-unverified")">
                    @(isPhoneConfirmed ? "\u2713" : "\u2717")
                </span>
            }
            else
            {
                <span class="status-icon-spacer"></span>
            }
        </div>
        <div class="field-actions">
            <a href="account/manage/edit_phone" class="btn btn-default field-action">Edit</a>
            @if (IsPhoneConfirmationEnabled && !string.IsNullOrEmpty(phoneNumber) && !isPhoneConfirmed)
            {
                <form method="post" @formname="confirm-phone" @onsubmit="OnSendPhoneVerificationAsync" style="display:inline;">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-default field-action">Confirm Phone</button>
                </form>
            }
        </div>
    </div>
</div>
