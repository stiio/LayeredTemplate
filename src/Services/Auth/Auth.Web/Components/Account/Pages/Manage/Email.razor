@page "/Account/Manage/Email"

<PageTitle>Manage email</PageTitle>

<h3>Manage email</h3>

<StatusMessage Message="@message"/>
<div class="card">
    <form @onsubmit="OnSendEmailVerificationAsync" @formname="send-verification" id="send-verification-form" method="post">
        <AntiforgeryToken/>
    </form>
    <EditForm Model="Input" method="post" FormName="change-email" OnValidSubmit="OnValidSubmitAsync">
        <DataAnnotationsValidator />

        @if (isEmailConfirmed)
        {
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <div style="display:flex; align-items:center; gap:8px;">
                    <input type="text" value="@email" id="email" disabled placeholder="Enter your email" class="form-input" />
                    <span style="color:#52c41a; font-weight:bold; font-size:18px;">&#10003;</span>
                </div>
            </div>
        }
        else
        {
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input type="text" value="@email" id="email" disabled placeholder="Enter your email" class="form-input" />
                <button type="submit" form="send-verification-form" style="background:none; border:none; color:#1677ff; cursor:pointer; padding:4px 0; font-size:14px;">Send verification email</button>
            </div>
        }
        <div class="form-group">
            <label for="@Input.NewEmail" class="form-label">New email</label>
            <InputText @bind-Value="Input.NewEmail" name="Input.NewEmail" class="form-input" placeholder="Enter a new email" />
        </div>
        <button type="submit" class="btn-primary btn-block">Change email</button>
    </EditForm>
</div>
