@page "/Account/Manage/EditPhone"

<PageTitle>Edit phone number</PageTitle>

<h3>Edit phone number</h3>
<StatusMessage Message="@message"/>

<div class="card">
    @if (!IsVerifyStep)
    {
        <EditForm Model="PhoneInput" method="post" FormName="send-code" OnValidSubmit="OnSendCodeAsync">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label class="form-label" for="@PhoneInput.PhoneNumber">Phone number</label>
                <InputText @bind-Value="PhoneInput.PhoneNumber" name="PhoneInput.PhoneNumber" class="form-input"
                           placeholder="+1234567890" />
                <ValidationMessage For="() => PhoneInput.PhoneNumber" />
            </div>
            <button type="submit" class="btn-primary btn-block">Send code</button>
        </EditForm>
    }
    else
    {
        <div class="form-group">
            <label class="form-label">Phone number</label>
            <input type="text" value="@Phone" disabled class="form-input" />
        </div>

        <EditForm Model="CodeInput" method="post" FormName="verify-code" OnValidSubmit="OnVerifyCodeAsync">
            <DataAnnotationsValidator />
            <input type="hidden" name="CodeInput.PhoneNumber" value="@Phone" />

            <div class="form-group">
                <label class="form-label" for="@CodeInput.Code">Verification code</label>
                <InputText @bind-Value="CodeInput.Code" name="CodeInput.Code" class="form-input"
                           placeholder="Enter code" />
                <ValidationMessage For="() => CodeInput.Code" />
            </div>
            <button type="submit" class="btn-primary btn-block">Verify</button>
        </EditForm>

        <div style="margin-top: 12px; text-align: center;">
            <form method="post" @formname="resend-code" @onsubmit="OnResendCodeAsync" style="display:inline;">
                <AntiforgeryToken />
                <button type="submit" id="resend-btn" class="btn-link">Resend code</button>
            </form>
        </div>

        <script>
            (function() {
                var btn = document.getElementById('resend-btn');
                if (!btn) return;
                var seconds = 60;
                var originalText = btn.textContent;
                btn.disabled = true;
                btn.style.opacity = '0.5';
                btn.style.cursor = 'not-allowed';
                var timer = setInterval(function() {
                    seconds--;
                    btn.textContent = 'Resend code (' + seconds + 's)';
                    if (seconds <= 0) {
                        clearInterval(timer);
                        btn.textContent = originalText;
                        btn.disabled = false;
                        btn.style.opacity = '1';
                        btn.style.cursor = 'pointer';
                    }
                }, 1000);
            })();
        </script>
    }

    <hr />
    <div style="text-align: center;">
        <a href="Account/Manage">Back to profile</a>
    </div>
</div>
