@page "/Account/Manage/ChangePassword"

<PageTitle>Change password</PageTitle>

<h3>Change password</h3>
<StatusMessage Message="@message"/>

<div style="max-width:400px;">
    <form method="post" @formname="change-password" @onsubmit="OnValidSubmitAsync">
        <AntiforgeryToken />

        <div style="margin-bottom:16px;">
            <label for="Input.OldPassword" style="display:block; margin-bottom:4px; font-weight:500;">Old password</label>
            <input type="password" name="Input.OldPassword" id="Input.OldPassword" value="@Input.OldPassword" style="width:100%; padding:8px 12px; border:1px solid #d9d9d9; border-radius:6px; font-size:14px;" autocomplete="current-password" aria-required="true" placeholder="Enter the old password" />
        </div>
        <div style="margin-bottom:16px;">
            <label for="Input.NewPassword" style="display:block; margin-bottom:4px; font-weight:500;">New password</label>
            <input type="password" name="Input.NewPassword" id="Input.NewPassword" value="@Input.NewPassword" style="width:100%; padding:8px 12px; border:1px solid #d9d9d9; border-radius:6px; font-size:14px;" autocomplete="new-password" aria-required="true" placeholder="Enter the new password" />
        </div>
        <div style="margin-bottom:16px;">
            <label for="Input.ConfirmPassword" style="display:block; margin-bottom:4px; font-weight:500;">Confirm password</label>
            <input type="password" name="Input.ConfirmPassword" id="Input.ConfirmPassword" value="@Input.ConfirmPassword" style="width:100%; padding:8px 12px; border:1px solid #d9d9d9; border-radius:6px; font-size:14px;" autocomplete="new-password" aria-required="true" placeholder="Enter the new password" />
        </div>
        <button type="submit" style="width:100%; padding:8px 16px; background:#1677ff; color:white; border:none; border-radius:6px; cursor:pointer; font-size:16px;">Update password</button>
    </form>
</div>
