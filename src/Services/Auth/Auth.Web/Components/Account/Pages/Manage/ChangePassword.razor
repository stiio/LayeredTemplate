@page "/Account/Manage/ChangePassword"

<PageTitle>Change password</PageTitle>

<h3>Change password</h3>
<StatusMessage Message="@message"/>

<div class="card">
    <EditForm Model="Input" method="post" FormName="change-password" OnValidSubmit="OnValidSubmitAsync">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label for="@Input.OldPassword" class="form-label">Old password</label>
            <div class="password-wrapper">
                <InputText type="password" @bind-Value="Input.OldPassword" name="Input.OldPassword" class="form-input" placeholder="Enter the old password" />
                <button type="button" class="password-toggle" aria-label="Toggle password">&#x25C8;</button>
            </div>
        </div>
        <div class="form-group">
            <label for="@Input.NewPassword" class="form-label">New password</label>
            <div class="password-wrapper">
                <InputText type="password" @bind-Value="Input.NewPassword" name="Input.NewPassword" class="form-input" placeholder="Enter the new password" />
                <button type="button" class="password-toggle" aria-label="Toggle password">&#x25C8;</button>
            </div>
        </div>
        <div class="form-group">
            <label for="@Input.ConfirmPassword" class="form-label">Confirm password</label>
            <div class="password-wrapper">
                <InputText type="password" @bind-Value="Input.ConfirmPassword" name="Input.ConfirmPassword" class="form-input" placeholder="Enter the new password" />
                <button type="button" class="password-toggle" aria-label="Toggle password">&#x25C8;</button>
            </div>
        </div>
        <button type="submit" class="btn-primary btn-block">Update password</button>
    </EditForm>
</div>
