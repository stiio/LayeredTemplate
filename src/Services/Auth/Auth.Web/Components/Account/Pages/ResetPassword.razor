@page "/account/reset_password"

<PageTitle>Reset password</PageTitle>

<div class="card">
    <h3 style="text-align: center;">Reset password</h3>
    <p>Reset your password.</p>

    <hr />

    <StatusMessage Message="@Message"/>

    <EditForm Model="Input" method="post" FormName="reset-password" OnValidSubmit="OnValidSubmitAsync">
        <DataAnnotationsValidator />

        <input type="hidden" name="Input.Code" value="@Input.Code"/>

        <div class="form-group">
            <label for="Input.Email" class="form-label">Email</label>
            <InputText @bind-Value="Input.Email" name="Input.Email" id="Input.Email" readonly="true"
                   placeholder="name@example.com" class="form-input" />
        </div>

        <div class="form-group">
            <label for="Input.Password" class="form-label">Password</label>
            <div class="password-wrapper">
                <InputText @bind-Value="Input.Password" name="Input.Password" id="Input.Password"
                       type="password" placeholder="Please enter your password." class="form-input" />
                <button type="button" class="password-toggle" aria-label="Toggle password">&#x25C8;</button>
            </div>
        </div>

        <div class="form-group">
            <label for="Input.ConfirmPassword" class="form-label">Confirm password</label>
            <div class="password-wrapper">
                <InputText @bind-Value="Input.ConfirmPassword" name="Input.ConfirmPassword" id="Input.ConfirmPassword"
                       type="password" placeholder="Please confirm your password." class="form-input" />
                <button type="button" class="password-toggle" aria-label="Toggle password">&#x25C8;</button>
            </div>
        </div>

        <button type="submit" class="btn-primary btn-block">Reset</button>
    </EditForm>
</div>
