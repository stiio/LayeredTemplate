@page "/Account/Register"

<PageTitle>Register</PageTitle>

<StatusMessage Message="@Message"/>

<div style="background: #fff; padding: 32px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <h3 style="text-align: center; margin-bottom: 24px;">Register</h3>

    <form method="post" @formname="register" @onsubmit="RegisterUser" id="register-form">
        <AntiforgeryToken/>
        <ReCaptcha FormId="register-form" />

        @if (!string.IsNullOrEmpty(Message))
        {
            <div style="padding: 8px 12px; margin-bottom: 16px; border: 1px solid #ffccc7; border-radius: 6px; background: #fff2f0; color: #a8071a;">
                @Message
            </div>
        }

        <div style="margin-bottom: 16px;">
            <label for="Input.Email" style="display: block; margin-bottom: 4px; font-size: 14px;">Email</label>
            <input type="email" name="Input.Email" id="Input.Email" value="@Input.Email" required autocomplete="username"
                   placeholder="name@example.com"
                   style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 6px; font-size: 14px; box-sizing: border-box;"/>
        </div>

        <div style="margin-bottom: 16px;">
            <label for="Input.Password" style="display: block; margin-bottom: 4px; font-size: 14px;">Password</label>
            <input type="password" name="Input.Password" id="Input.Password" required autocomplete="new-password"
                   placeholder="Password"
                   style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 6px; font-size: 14px; box-sizing: border-box;"/>
        </div>

        <div style="margin-bottom: 16px;">
            <label for="Input.ConfirmPassword" style="display: block; margin-bottom: 4px; font-size: 14px;">Confirm Password</label>
            <input type="password" name="Input.ConfirmPassword" id="Input.ConfirmPassword" required autocomplete="new-password"
                   placeholder="Confirm password"
                   style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 6px; font-size: 14px; box-sizing: border-box;"/>
        </div>

        <button type="submit"
                style="width: 100%; padding: 8px 16px; background: #1677ff; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 16px;">
            Register
        </button>
    </form>

    <div style="margin-top: 16px; text-align: center; font-size: 14px;">
        <p><a href="@(NavigationManager.GetUriWithQueryParameters("Account/Login", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))" style="color: #1677ff;">Already have an account? Log in</a></p>
    </div>
</div>
