@page "/Account/Register"

<PageTitle>Register</PageTitle>

<StatusMessage Message="@Message"/>

<div class="card">
    <h3 style="text-align: center;">Register</h3>

    <EditForm Model="Input" method="post" FormName="register" OnValidSubmit="RegisterUser" id="register-form">
        <DataAnnotationsValidator />
        <ReCaptcha FormId="register-form" />

        <div class="form-group">
            <label class="form-label" for="Input.Email">Email</label>
            <InputText @bind-Value="Input.Email" id="Input.Email" name="Input.Email" class="form-input"
                       placeholder="@("name@example.com")" autocomplete="username" />
            <ValidationMessage For="() => Input.Email" />
        </div>

        <div class="form-group">
            <label class="form-label" for="Input.Password">Password</label>
            <div class="password-wrapper">
                <InputText @bind-Value="Input.Password" id="Input.Password" name="Input.Password" type="password" class="form-input"
                           placeholder="Password" autocomplete="new-password" />
                <button type="button" class="password-toggle" aria-label="Toggle password">&#x25C8;</button>
            </div>
            <ValidationMessage For="() => Input.Password" />
        </div>

        <div class="form-group">
            <label class="form-label" for="Input.ConfirmPassword">Confirm Password</label>
            <div class="password-wrapper">
                <InputText @bind-Value="Input.ConfirmPassword" id="Input.ConfirmPassword" name="Input.ConfirmPassword" type="password" class="form-input"
                           placeholder="Confirm password" autocomplete="new-password" />
                <button type="button" class="password-toggle" aria-label="Toggle password">&#x25C8;</button>
            </div>
            <ValidationMessage For="() => Input.ConfirmPassword" />
        </div>

        <button type="submit" class="btn-primary btn-block">Register</button>
    </EditForm>

    <hr />

    <div style="text-align: center;">
        <p><a href="@(NavigationManager.GetUriWithQueryParameters("Account/Login", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Already have an account? Log in</a></p>
    </div>
</div>
