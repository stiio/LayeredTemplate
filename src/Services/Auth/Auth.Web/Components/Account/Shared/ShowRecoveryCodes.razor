<StatusMessage Message="@StatusMessage"/>
<h3>Recovery codes</h3>
<div style="padding: 12px 16px; background: #fff7e6; border: 1px solid #ffd591; border-radius: 6px; margin-bottom: 16px;" role="alert">
    <p><strong>Put these codes in a safe place.</strong></p>
    <p>If you lose your device and don't have the recovery codes you will lose access to your account.</p>
</div>
<div>
    @foreach (var recoveryCode in RecoveryCodes)
    {
        <div><code>@recoveryCode</code></div>
    }
</div>
